  "description": "Benji Peng — scientist & entrepreneur personal site",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "playwright test --config=playwright.unit.config.ts",
