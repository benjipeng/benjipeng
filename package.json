    "@vitejs/plugin-react-swc": "^4.3.1",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.49.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "framer-motion": "^12.15.0",
    "lucide-react": "^0.511.0",
