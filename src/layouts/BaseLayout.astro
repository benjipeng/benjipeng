---
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
const canonicalUrl = "https://benjipeng.github.io/benjipeng/";
const title = "APPCUBIC — Machine Garden";
const description =
  "APPCUBIC is an AI design studio — agentic systems cultivated: planted as research, pruned by evaluation, harvested as products.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="APPCUBIC" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preload" href={`${base}/fonts/clash-display-600.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}/fonts/playfair-italic-var.woff2`} as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
